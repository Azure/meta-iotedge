# Source-compatibility patches for the 1.6.0 edgelet workspace. The set is
# version-specific (the upstream Cargo.toml and source layout differ by
# release), so it is wired here rather than in the shared iotedge.inc. This
# lets 1.5.x and 1.6.x recipes coexist on the same branch. Generated by
# scripts/update-recipes.sh from the patch files in the recipe's patch dir.
SRC_URI += "file://0001-Remove-panic-abort-from-workspace-profiles.patch \
            file://0002-Pin-sysinfo-0.38-for-Yocto-Rust-1.94.patch \
"
